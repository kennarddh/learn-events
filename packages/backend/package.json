{
	"name": "@learn-events/backend",
	"version": "1.0.0",
	"description": "Backend for Learn Events",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"start": "cross-env NODE_ENV=development tsx watch --env-file=.env ./src/index.ts",
		"build": "npm run clean:build && tsx ./scripts/build.ts",
		"prod": "cross-env NODE_ENV=production node --env-file=.env ./build/index.js",
		"clean": "concurrently \"npm run clean:build\" \"npm run clean:logs\"",
		"clean:build": "rimraf ./build",
		"clean:logs": "rimraf ./Logs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kennarddh/learn-events.git"
	},
	"bugs": {
		"url": "https://github.com/kennarddh/learn-events/issues"
	},
	"homepage": "https://github.com/kennarddh/learn-events#readme",
	"author": "kennarddh",
	"dependencies": {
		"@celosiajs/core": "^0.0.1-alpha.39",
		"@celosiajs/logging": "^0.0.1-alpha.26",
		"@prisma/adapter-pg": "^6.9.0",
		"@prisma/client": "^6.9.0",
		"@learn-events/common": "^1.0.0",
		"argon2": "^0.43.0",
		"cors": "^2.8.5",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.2",
		"mergician": "^2.0.2",
		"rate-limiter-flexible": "^7.1.1",
		"winston": "^3.17.0",
		"winston-daily-rotate-file": "^5.0.0",
		"zod": "^3.25.51"
	},
	"devDependencies": {
		"@types/cors": "^2.8.18",
		"@types/jsonwebtoken": "^9.0.9",
		"dotenv": "^17.2.3",
		"esbuild": "^0.25.5",
		"prisma": "^6.9.0"
	},
	"prisma": {
		"seed": "tsx --env-file=.env ./prisma/seed.ts"
	}
}
